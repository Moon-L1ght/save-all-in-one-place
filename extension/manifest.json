{
  "manifest_version": 3,
  "name": "SaveVault",
  "version": "0.1.0",
  "description": "Save social media posts and web pages to your personal archive",
  "permissions": ["storage", "activeTab", "contextMenus"],
  "host_permissions": ["*://*/*"],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "SaveVault"
  },
  "background": {
    "service_worker": "src/background.ts"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
